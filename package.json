{
  "name": "@overgaming/valiform",
  "version": "0.4.0",
  "description": "Vue 3 form validation library",
  "keywords": [
    "form",
    "nuxt",
    "validation",
    "vue",
    "vue3"
  ],
  "license": "MIT",
  "author": "OverGaming",
  "repository": {
    "type": "git",
    "url": "https://github.com/OverGaming/valiform"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.ts",
      "import": "./dist/nuxt.js",
      "require": "./dist/nuxt.cjs"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint src nuxt",
    "lint:fix": "oxlint src nuxt --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vueuse/core": "^14.2.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^4.0.18",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "@nuxt/kit": ">=3.0.0",
    "@vueuse/core": "^10.0.0 || ^11.0.0 || ^12.0.0 || ^13.0.0 || ^14.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.{ts,vue,js}": [
      "oxfmt",
      "oxlint"
    ],
    "*.{json,md}": [
      "oxfmt"
    ]
  }
}
